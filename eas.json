{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": true },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://bpvrqphmxrnjrbjtaxuw.supabase.co"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "channel": "preview"
    },
    "production": {
      "ios": {
        "autoIncrement": "buildNumber",
        "image": "latest"
      },
      "android": {
        "buildType": "app-bundle",
        "autoIncrement": "versionCode",
        "image": "latest"
      },
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "moussati.nourdin@gmail.com",
        "ascAppId": "REMPLIR_APRES_CREATION_APP_STORE_CONNECT",
        "appleTeamId": "REMPLIR_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./play-store-key.json",
        "track": "internal"
      }
    }
  }
}
